{
  "name": "libby-downloader",
  "version": "1.1.0",
  "description": "CLI tool for managing audiobooks downloaded from Libby via Chrome extension",
  "main": "dist/index.js",
  "bin": {
    "libby": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:cli && npm run build:extension",
    "build:cli": "tsc",
    "build:extension": "node scripts/build-extension.mjs",
    "build:extension:watch": "vite build --watch",
    "dev": "tsx src/cli.ts",
    "dev:extension": "vite build --watch",
    "start": "node dist/cli.js",
    "watch": "tsc --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "check-all": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepare": "husky",
    "extension:lint": "web-ext lint --source-dir=chrome-extension --warnings-as-errors",
    "extension:validate": "node scripts/validate-extension.cjs",
    "lint:claude": "claudelint check-all",
    "lint:claude:fix": "claudelint format --fix",
    "fixtures": "bash scripts/generate-fixtures.sh",
    "fixtures:clean": "bash scripts/generate-fixtures.sh --clean",
    "test:cli": "bash scripts/test-cli.sh",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "keywords": [
    "libby",
    "audiobook",
    "downloader",
    "overdrive"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "fluent-ffmpeg": "^2.1.3",
    "ink": "^6.8.0",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "node-id3": "^0.2.9",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/chrome": "^0.1.37",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.53.0",
    "claude-code-lint": "^0.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "ink-testing-library": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.2",
    "web-ext": "^9.4.0"
  }
}
